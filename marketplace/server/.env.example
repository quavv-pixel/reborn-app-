PORT=4000
FRONTEND_URL=http://localhost:5173

# Generate a long random string for production, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# SQLite file path (defaults to server/data/marketplace.db if omitted)
DATABASE_PATH=./data/marketplace.db

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen --forward-to localhost:4000/api/webhooks/stripe` during local dev,
# or from your Stripe webhook endpoint settings in production.
STRIPE_WEBHOOK_SECRET=whsec_xxx
